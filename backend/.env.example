# ================================================
# CONFIGURATION PORTFOLIO ADMIN
# ================================================

# Port du serveur admin
ADMIN_PORT=3001

# ================================================
# SÉCURITÉ - IMPORTANT !
# ================================================

# Secret JWT - Générez une clé aléatoire de 64 caractères minimum
# Commande: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEZ_MOI_AVEC_UNE_CLE_ALEATOIRE_DE_64_CARACTERES_MINIMUM

# Hash du mot de passe admin (bcrypt)
# Générez avec: node -e "console.log(require('bcryptjs').hashSync('VOTRE_MOT_DE_PASSE', 12))"
ADMIN_PASSWORD_HASH=$2a$12$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Mode production (active les vérifications strictes)
# NODE_ENV=production

# ================================================
# CORS - Origines autorisées (séparées par des virgules)
# ================================================
# ALLOWED_ORIGINS=https://votre-domaine.com,https://admin.votre-domaine.com

# ================================================
# OPTIONNEL - Discord (si vous utilisez les notifications)
# ================================================
# DISCORD_BOT_TOKEN=votre_token_bot
# DISCORD_USER_ID=votre_id_utilisateur
